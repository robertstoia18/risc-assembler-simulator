<Window x:Class="RiscEmulator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RiscEmulator.UI.ViewModels"
        Title="RISC 5-Stage Pipeline Simulator Architecture — AC" Height="900" Width="1440"
        Background="#0A0A0A" Foreground="#D4D4D4"
        WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>

		<Style x:Key="BusLabel" TargetType="TextBlock">
			<Setter Property="Foreground" Value="#858585"/>
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="FontFamily" Value="Consolas"/>
		</Style>

		<Style x:Key="StageTitle" TargetType="TextBlock">
			<Setter Property="Foreground" Value="#569CD6"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>

		<Style x:Key="HardwareValue" TargetType="TextBlock">
			<Setter Property="Foreground" Value="#4EC9B0"/>
			<Setter Property="FontFamily" Value="Consolas"/>
			<Setter Property="FontSize" Value="11"/>
		</Style>

		<Style x:Key="ClockButton" TargetType="Button">
			<Setter Property="Background" Value="#1E3A2F"/>
			<Setter Property="Foreground" Value="#52B788"/>
			<Setter Property="BorderBrush" Value="#2D6A4F"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="14,7"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#2D6A4F"/>
					<Setter Property="Foreground" Value="White"/>
				</Trigger>
				<Trigger Property="IsEnabled" Value="False">
					<Setter Property="Background" Value="#1A1A1A"/>
					<Setter Property="Foreground" Value="#555"/>
					<Setter Property="BorderBrush" Value="#222"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<!-- Template pentru stagii pipeline -->
		<DataTemplate x:Key="StageTemplate">
			<Border Background="#161616" BorderBrush="#333" BorderThickness="1" Padding="6" CornerRadius="4" Margin="0,0,2,0">
				<Border.Style>
					<Style TargetType="Border">
						<Style.Triggers>
							<DataTrigger Binding="{Binding IsStall}" Value="True">
								<Setter Property="Background" Value="#2A1010"/>
								<Setter Property="BorderBrush" Value="#C0392B"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding HasForwarding}" Value="True">
								<Setter Property="Background" Value="#1A2A10"/>
								<Setter Property="BorderBrush" Value="#F0C030"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</Border.Style>
				<StackPanel>
					<TextBlock Text="{Binding StageName}" Style="{StaticResource StageTitle}"/>
					<Separator Background="#222" Margin="0,2,0,4"/>

					<Border Background="#244B66" Padding="4" CornerRadius="2" HorizontalAlignment="Center" Margin="0,0,0,6">
						<TextBlock Text="{Binding InstructionLabel}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="White"/>
					</Border>

					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
						<Border Background="#C0392B" CornerRadius="2" Padding="3,1" Margin="2,0" Visibility="{Binding IsStall, Converter={StaticResource BoolToVis}}">
							<TextBlock Text="STALL" Foreground="White" FontSize="8" FontWeight="Bold"/>
						</Border>
						<Border Background="#F0C030" CornerRadius="2" Padding="3,1" Margin="2,0" Visibility="{Binding HasForwarding, Converter={StaticResource BoolToVis}}">
							<TextBlock Text="FWD" Foreground="#111" FontSize="8" FontWeight="Bold"/>
						</Border>
					</StackPanel>

					<TextBlock Margin="0,6,0,0" FontSize="9" Foreground="#858585" FontFamily="Consolas" Text="A:"/>
					<TextBlock Text="{Binding AHex}" Style="{StaticResource HardwareValue}" Margin="0,0,0,2"/>

					<TextBlock FontSize="9" Foreground="#858585" FontFamily="Consolas" Text="B:"/>
					<TextBlock Text="{Binding BHex}" Style="{StaticResource HardwareValue}" Margin="0,0,0,2"/>

					<TextBlock FontSize="9" Foreground="#858585" FontFamily="Consolas" Text="C:"/>
					<TextBlock Text="{Binding CHex}" Style="{StaticResource HardwareValue}" Margin="0,0,0,2"/>

					<TextBlock FontSize="9" Foreground="#858585" FontFamily="Consolas" Text="MAR:"/>
					<TextBlock Text="{Binding MARHex}" Style="{StaticResource HardwareValue}"/>
				</StackPanel>
			</Border>
		</DataTemplate>

		<!-- Template pentru registru -->
		<DataTemplate x:Key="RegisterItemTemplate">
			<Border Background="#161616" BorderBrush="#252526" BorderThickness="1" Margin="2" Padding="4" CornerRadius="2">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="32"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="14"/>
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0" Text="{Binding Label}" FontFamily="Consolas" Foreground="#569CD6" FontWeight="Bold" FontSize="11"/>
					<TextBlock Grid.Column="1" Text="{Binding DisplayValue}" FontFamily="Consolas" Foreground="#4EC9B0" FontSize="11"/>
					<Ellipse Grid.Column="2" Width="8" Height="8" VerticalAlignment="Center" HorizontalAlignment="Right">
						<Ellipse.Style>
							<Style TargetType="Ellipse">
								<Setter Property="Fill" Value="#52B788"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsValid}" Value="False">
										<Setter Property="Fill" Value="#E06C75"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Ellipse.Style>
					</Ellipse>
				</Grid>
			</Border>
		</DataTemplate>

	</Window.Resources>

	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="150"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="240"/>
		</Grid.RowDefinitions>

		<!-- ===== RÂNDUL 0: Editor + Controale ===== -->
		<Grid Grid.Row="0" Margin="0,0,0,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="320"/>
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0" Background="#111" BorderBrush="#252526" BorderThickness="1" CornerRadius="4" Padding="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<TextBlock Grid.Row="0" Text="📝 Memorare Instrucțiuni (Cod Sursă RISC ALU / LD / ST / JMP)" Foreground="#569CD6" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
					<TextBox Grid.Row="1" Text="{Binding ProgramSource, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" FontFamily="Consolas" FontSize="12" Background="#0A0A0A" Foreground="#D4D4D4"
                             BorderBrush="#2D2D2D" VerticalScrollBarVisibility="Auto" Padding="6"/>
				</Grid>
			</Border>

			<Border Grid.Column="1" Background="#111" BorderBrush="#252526" BorderThickness="1" CornerRadius="4" Padding="10" Margin="10,0,0,0">
				<StackPanel VerticalAlignment="Center">
					<Grid Margin="0,0,0,6">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Adresă Start PC (Hex):" VerticalAlignment="Center" FontSize="11" Foreground="#858585"/>
						<TextBox Grid.Column="1" Text="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0A0A0A" Foreground="#4EC9B0" FontFamily="Consolas" FontWeight="Bold"
                                 TextAlignment="Center" BorderBrush="#2D2D2D" Margin="8,0,0,0" Height="24" VerticalContentAlignment="Center"/>
					</Grid>

					<UniformGrid Columns="3" Height="32">
						<Button Content="📥 LOAD" Command="{Binding LoadProgramCommand}" Style="{StaticResource ClockButton}" Margin="0,0,4,0"/>
						<Button Content="⏱️ NEXT" Command="{Binding NextClockCommand}" Style="{StaticResource ClockButton}" Margin="0,0,4,0" Background="#122B3D" Foreground="#569CD6" BorderBrush="#244B66"/>
						<Button Content="⟳ RESET" Command="{Binding ResetCommand}" Style="{StaticResource ClockButton}" Background="#3A1E1E" Foreground="#E06C75" BorderBrush="#6D1A1A"/>
					</UniformGrid>

					<Border Background="#161616" Margin="0,6,0,0" Padding="6" CornerRadius="2">
						<Grid>
							<TextBlock TextAlignment="Left" FontSize="11">
								<Run Text="Ciclu Ceas: " Foreground="#858585"/>
								<Run Text="{Binding CycleCount}" Foreground="#DCDCAA" FontWeight="Bold" FontSize="13"/>
							</TextBlock>
							<TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Right" Foreground="#E06C75" FontSize="10" VerticalAlignment="Center" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
						</Grid>
					</Border>
				</StackPanel>
			</Border>
		</Grid>

		<!-- ===== RÂNDUL 1: Pipeline (5 stagii afișate individual) ===== -->
		<Border Grid.Row="1" Background="#111" BorderBrush="#252526" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<ContentControl Grid.Column="0" Content="{Binding PipelineSlots[0]}" ContentTemplate="{StaticResource StageTemplate}" Margin="0,0,2,0"/>
				<ContentControl Grid.Column="1" Content="{Binding PipelineSlots[1]}" ContentTemplate="{StaticResource StageTemplate}" Margin="2,0"/>
				<ContentControl Grid.Column="2" Content="{Binding PipelineSlots[2]}" ContentTemplate="{StaticResource StageTemplate}" Margin="2,0"/>
				<ContentControl Grid.Column="3" Content="{Binding PipelineSlots[3]}" ContentTemplate="{StaticResource StageTemplate}" Margin="2,0"/>
				<ContentControl Grid.Column="4" Content="{Binding PipelineSlots[4]}" ContentTemplate="{StaticResource StageTemplate}" Margin="2,0,0,0"/>
			</Grid>
		</Border>

		<!-- ===== RÂNDUL 2: Registre + Memorie ===== -->
		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="3*"/>
				<ColumnDefinition Width="2*"/>
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0" Background="#111" BorderBrush="#252526" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,10,0">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
						<TextBlock Text="📋 Banc de Registre (R0 - R31)" Foreground="#569CD6" FontWeight="SemiBold" FontSize="12"/>
						<TextBlock Text="  [● Valid / ● Invalid]" Foreground="#858585" FontSize="10" VerticalAlignment="Center"/>
					</StackPanel>

					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
						<ItemsControl ItemsSource="{Binding Registers}" ItemTemplate="{StaticResource RegisterItemTemplate}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid Columns="4"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</Border>

			<Border Grid.Column="1" Background="#111" BorderBrush="#252526" BorderThickness="1" CornerRadius="4" Padding="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<TextBlock Grid.Row="0" Text="💾 Memorie Date RAM" Foreground="#569CD6" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>

					<DataGrid Grid.Row="1" ItemsSource="{Binding MemoryRows}" AutoGenerateColumns="False"
                              Background="#0A0A0A" RowBackground="#161616" AlternatingRowBackground="#1A1A1A"
                              BorderThickness="0" Foreground="#D4D4D4" GridLinesVisibility="None" IsReadOnly="True" HeadersVisibility="Column"
                              FontSize="11" FontFamily="Consolas">
						<DataGrid.Resources>
							<Style TargetType="DataGridColumnHeader">
								<Setter Property="Background" Value="#252526"/>
								<Setter Property="Foreground" Value="#AAA"/>
								<Setter Property="FontFamily" Value="Segoe UI"/>
								<Setter Property="FontSize" Value="11"/>
								<Setter Property="Padding" Value="4"/>
							</Style>
						</DataGrid.Resources>
						<DataGrid.Columns>
							<DataGridTextColumn Header="Adresă" Binding="{Binding AddressHex}" Width="1.5*" ElementStyle="{StaticResource HardwareValue}"/>
							<DataGridTextColumn Header="Valoare" Binding="{Binding ValueHex}" Width="2*" ElementStyle="{StaticResource HardwareValue}"/>
							<DataGridTextColumn Header="" Binding="{Binding PCIndicator}" Width="*" Foreground="#DCDCAA"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>