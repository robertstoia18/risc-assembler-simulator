<Window x:Class="RiscEmulator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RiscEmulator.UI.ViewModels"
        Title="RISC Pipeline Simulator — AC (Ext 1.0/1.1/1.2/1.3)" Height="900" Width="1500"
        Background="#F5F5F5" Foreground="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ===== STILURI ===== -->
        <Style x:Key="StageTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2C5F8A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="HardwareValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1A7A5A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ClockButton" TargetType="Button">
            <Setter Property="Background" Value="#E8F0FE"/>
            <Setter Property="Foreground" Value="#1A5276"/>
            <Setter Property="BorderBrush" Value="#85A9C4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D4E6F1"/>
                    <Setter Property="Foreground" Value="#0D3B5E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#999"/>
                    <Setter Property="BorderBrush" Value="#CCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== TEMPLATE PIPELINE STAGE ===== -->
        <DataTemplate x:Key="StageTemplate">
            <Border Background="#FAFAFA" BorderBrush="#D0D0D0" BorderThickness="1" Padding="5" CornerRadius="3" Margin="0,0,2,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStall}" Value="True">
                                <Setter Property="Background" Value="#FDDEDE"/>
                                <Setter Property="BorderBrush" Value="#D32F2F"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasForwarding}" Value="True">
                                <Setter Property="Background" Value="#FFF8E1"/>
                                <Setter Property="BorderBrush" Value="#F9A825"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding StageName}" Style="{StaticResource StageTitle}"/>
                    <Border Background="#D4E6F1" Padding="3" CornerRadius="2" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="{Binding InstructionLabel}" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="#0D3B5E"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,2">
                        <Border Background="#D32F2F" CornerRadius="2" Padding="2,1" Margin="1,0"
                                Visibility="{Binding IsStall, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="STALL" Foreground="White" FontSize="7" FontWeight="Bold"/>
                        </Border>
                        <Border Background="#F9A825" CornerRadius="2" Padding="2,1" Margin="1,0"
                                Visibility="{Binding HasForwarding, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="FWD" Foreground="#1E1E1E" FontSize="7" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding AHex}" Style="{StaticResource HardwareValue}" FontSize="9"/>
                    <TextBlock Text="{Binding BHex}" Style="{StaticResource HardwareValue}" FontSize="9"/>
                    <TextBlock Text="{Binding CHex}" Style="{StaticResource HardwareValue}" FontSize="9"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== TEMPLATE REGISTRU ===== -->
        <DataTemplate x:Key="RegisterItemTemplate">
            <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" Margin="1" Padding="3" CornerRadius="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontFamily="Consolas" Foreground="#2C5F8A" FontWeight="Bold" FontSize="10"/>
                    <TextBlock Grid.Column="1" Text="{Binding DisplayValue}" FontFamily="Consolas" Foreground="#1A7A5A" FontSize="10"/>
                    <Ellipse Grid.Column="2" Width="7" Height="7" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#388E3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="Fill" Value="#D32F2F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ===== DATA GRID STIL ===== -->
        <Style x:Key="AlgoGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style x:Key="TabHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <TabControl Background="#F5F5F5" BorderBrush="#D0D0D0" Margin="4">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Background" Value="#E8E8E8"/>
                <Setter Property="Foreground" Value="#555"/>
                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="FontSize" Value="12"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1E1E1E"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </TabControl.Resources>

        <!-- ===== TAB 1: PIPELINE ===== -->
        <TabItem Header="1.0 — Pipeline Superscalar" DataContext="{Binding Pipeline}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="140"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="230"/>
                </Grid.RowDefinitions>

                <!-- Editor -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Cod Sursă RISC" Foreground="#2C5F8A" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Grid.Row="1" Text="{Binding ProgramSource, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" FontFamily="Consolas" FontSize="11" Background="White" Foreground="#1E1E1E"
                                     BorderBrush="#D0D0D0" VerticalScrollBarVisibility="Auto" Padding="4"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="8,0,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Start PC:" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                                <TextBox Grid.Column="1" Text="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Background="White" Foreground="#1A7A5A" FontFamily="Consolas"
                                         BorderBrush="#D0D0D0" Margin="6,0,0,0" Height="22" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>
                            <UniformGrid Columns="3" Height="28" Margin="0,0,0,5">
                                <Button Content="LOAD" Command="{Binding LoadProgramCommand}" Style="{StaticResource ClockButton}" Margin="0,0,3,0"/>
                                <Button Content="NEXT" Command="{Binding NextClockCommand}" Style="{StaticResource ClockButton}" Margin="0,0,3,0" Background="#D4E6F1" Foreground="#1A5276" BorderBrush="#85A9C4"/>
                                <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ClockButton}" Background="#FDDEDE" Foreground="#C0392B" BorderBrush="#D32F2F"/>
                            </UniformGrid>
                            <Border Background="#F5F5F5" Padding="5" CornerRadius="2">
                                <Grid>
                                    <TextBlock FontSize="11">
                                        <Run Text="Tact: " Foreground="#555"/>
                                        <Run Text="{Binding CycleCount}" Foreground="#1A5276" FontWeight="Bold" FontSize="13"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Right" Foreground="#C0392B" FontSize="9" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Pipeline -->
                <Border Grid.Row="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <ContentControl Grid.Column="0" Content="{Binding PipelineSlots[0]}" ContentTemplate="{StaticResource StageTemplate}"/>
                            <ContentControl Grid.Column="1" Content="{Binding PipelineSlots[1]}" ContentTemplate="{StaticResource StageTemplate}" Margin="2,0,0,0"/>
                            <TextBlock Grid.Column="2" Padding="10,0,0,0" VerticalAlignment="Center" FontSize="10" Foreground="#777"
                                       Text="Ext 1.0 | 4 unități funcționale (ALU, MUL, LD/ST, JMP) | forwarding EX/MEM"/>
                        </Grid>
                        <Separator Grid.Row="1" Background="#D0D0D0" Margin="0,6,0,3"/>
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Units}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="3" Margin="2" Padding="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding UnitName}" FontWeight="Bold" Foreground="#6A1B9A" FontFamily="Segoe UI" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentControl Grid.Column="0" Content="{Binding EX}" ContentTemplate="{StaticResource StageTemplate}"/>
                                                <ContentControl Grid.Column="1" Content="{Binding MEM}" ContentTemplate="{StaticResource StageTemplate}" Margin="2,0,0,0"/>
                                                <ContentControl Grid.Column="2" Content="{Binding WB}" ContentTemplate="{StaticResource StageTemplate}" Margin="2,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Registre + Memorie + Cache I/D -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2.5*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Banc Registre R0-R31 [● Valid / ● Busy]" Foreground="#2C5F8A" FontSize="11" Margin="0,0,0,3"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Registers}" ItemTemplate="{StaticResource RegisterItemTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Memorie RAM" Foreground="#2C5F8A" FontSize="11" Margin="0,0,0,3"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding MemoryRows}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Adresă" Binding="{Binding AddressHex}" Width="1.5*" ElementStyle="{StaticResource HardwareValue}"/>
                                    <DataGridTextColumn Header="Valoare" Binding="{Binding ValueHex}" Width="2*" ElementStyle="{StaticResource HardwareValue}"/>
                                    <DataGridTextColumn Header="" Binding="{Binding PCIndicator}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Cache I/D (feature/cache-id-separate) -->
                    <Border Grid.Column="2" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,4">
                                <TextBlock Text="Cache I/D — politica de inlocuire" Foreground="#2C5F8A" FontSize="11" FontWeight="Bold"/>
                                <TextBlock FontSize="9" Foreground="#666" FontFamily="Consolas">
                                    <Run Text="I: "/>
                                    <Run Text="{Binding ICacheConfig, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock FontSize="9" Foreground="#666" FontFamily="Consolas">
                                    <Run Text="D: "/>
                                    <Run Text="{Binding DCacheConfig, Mode=OneWay}"/>
                                </TextBlock>
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="I:" FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                    <ComboBox Grid.Column="1" FontSize="10" Margin="0,0,4,0"
                                              ItemsSource="{Binding AvailablePolicies}"
                                              SelectedItem="{Binding ICacheReplacementPolicy}"/>
                                    <TextBlock Grid.Column="2" Text="D:" FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                    <ComboBox Grid.Column="3" FontSize="10" Margin="0,0,4,0"
                                              ItemsSource="{Binding AvailablePolicies}"
                                              SelectedItem="{Binding DCacheReplacementPolicy}"/>
                                    <Button Grid.Column="4" Content="Aplica" FontSize="10" Padding="6,1"
                                            Command="{Binding ReconfigureCacheCommand}"/>
                                </Grid>
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Scriere D:" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <ComboBox Grid.Column="1" FontSize="10"
                                              ItemsSource="{Binding AvailableWritePolicies}"
                                              SelectedItem="{Binding DCacheWritePolicy}"/>
                                </Grid>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- I-Cache -->
                                <Grid Grid.Column="0" Margin="0,0,3,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="I-Cache" Foreground="#1A5276" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Background="#EBF5FB" BorderBrush="#AED6F1" BorderThickness="1" CornerRadius="2" Padding="4,2" Margin="0,2,0,2">
                                        <TextBlock FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center">
                                            <Run Text="H:" Foreground="#555"/>
                                            <Run Text="{Binding ICacheHits}" Foreground="#1A7A5A" FontWeight="Bold"/>
                                            <Run Text="  M:" Foreground="#555"/>
                                            <Run Text="{Binding ICacheMisses}" Foreground="#C0392B" FontWeight="Bold"/>
                                            <Run Text="  HR:" Foreground="#555"/>
                                            <Run Text="{Binding ICacheHitRateText, Mode=OneWay}" Foreground="#1A5276" FontWeight="Bold"/>
                                        </TextBlock>
                                    </Border>
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ICacheBlocks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,1" Padding="2,1" CornerRadius="2" BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FAFAFA"/>
                                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Valid}" Value="True">
                                                                        <Setter Property="Background" Value="#EBF5FB"/>
                                                                        <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="20"/>
                                                                <ColumnDefinition Width="32"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Index}" FontFamily="Consolas" FontSize="9" Foreground="#999"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding ValidLabel}" FontFamily="Consolas" FontSize="9" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#999"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Valid}" Value="True">
                                                                                <Setter Property="Foreground" Value="#1A7A5A"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="2" Text="{Binding TagHex}" FontFamily="Consolas" FontSize="9" Foreground="#1A5276"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding DataPreview}" FontFamily="Consolas" FontSize="9" Foreground="#555" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>

                                <!-- D-Cache -->
                                <Grid Grid.Column="1" Margin="3,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="D-Cache" Foreground="#8B0000" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Background="#FDECEA" BorderBrush="#F5C6CB" BorderThickness="1" CornerRadius="2" Padding="4,2" Margin="0,2,0,2">
                                        <TextBlock FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center">
                                            <Run Text="H:" Foreground="#555"/>
                                            <Run Text="{Binding DCacheHits}" Foreground="#1A7A5A" FontWeight="Bold"/>
                                            <Run Text="  M:" Foreground="#555"/>
                                            <Run Text="{Binding DCacheMisses}" Foreground="#C0392B" FontWeight="Bold"/>
                                            <Run Text="  HR:" Foreground="#555"/>
                                            <Run Text="{Binding DCacheHitRateText, Mode=OneWay}" Foreground="#8B0000" FontWeight="Bold"/>
                                        </TextBlock>
                                    </Border>
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding DCacheBlocks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,1" Padding="2,1" CornerRadius="2" BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FAFAFA"/>
                                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Valid}" Value="True">
                                                                        <Setter Property="Background" Value="#FFF8F8"/>
                                                                        <Setter Property="BorderBrush" Value="#F5C6CB"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="20"/>
                                                                <ColumnDefinition Width="32"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Index}" FontFamily="Consolas" FontSize="9" Foreground="#999"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding ValidLabel}" FontFamily="Consolas" FontSize="9" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#999"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Valid}" Value="True">
                                                                                <Setter Property="Foreground" Value="#C0392B"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="2" Text="{Binding TagHex}" FontFamily="Consolas" FontSize="9" Foreground="#8B0000"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding DataPreview}" FontFamily="Consolas" FontSize="9" Foreground="#555" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ===== TAB 2: SCOREBOARD ===== -->
        <TabItem Header="1.1 — Scoreboard" DataContext="{Binding Scoreboard}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ProgramSource, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" FontFamily="Consolas" FontSize="11" Background="White" Foreground="#1E1E1E"
                                 BorderBrush="#D0D0D0" Height="80" VerticalScrollBarVisibility="Auto" Padding="4" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Start PC:" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                                <TextBox Grid.Column="1" Text="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Background="White" Foreground="#1A7A5A" FontFamily="Consolas" Height="22"
                                         BorderBrush="#D0D0D0" Margin="6,0,0,0" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding Status}" Foreground="#C0392B" FontSize="10" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="11" Margin="0,4,0,0">
                                <Run Text="Tact: " Foreground="#555"/>
                                <Run Text="{Binding CycleCount}" Foreground="#1A5276" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Button Content="LOAD" Command="{Binding LoadCommand}" Style="{StaticResource ClockButton}" Margin="0,0,0,4"/>
                            <Button Content="TICK" Command="{Binding TickCommand}" Style="{StaticResource ClockButton}" Background="#D4E6F1" Foreground="#1A5276" BorderBrush="#85A9C4" Margin="0,0,0,4"/>
                            <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ClockButton}" Background="#FDDEDE" Foreground="#C0392B" BorderBrush="#D32F2F"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Stare Unități Funcționale" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding FuTable}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="FU" Binding="{Binding FuName}" Width="50"/>
                                    <DataGridTextColumn Header="Busy" Binding="{Binding Busy}" Width="40"/>
                                    <DataGridTextColumn Header="Op" Binding="{Binding Op}" Width="50"/>
                                    <DataGridTextColumn Header="Fi" Binding="{Binding Fi}" Width="35"/>
                                    <DataGridTextColumn Header="Fj" Binding="{Binding Fj}" Width="35"/>
                                    <DataGridTextColumn Header="Fk" Binding="{Binding Fk}" Width="35"/>
                                    <DataGridTextColumn Header="Qj" Binding="{Binding Qj}" Width="50"/>
                                    <DataGridTextColumn Header="Qk" Binding="{Binding Qk}" Width="50"/>
                                    <DataGridTextColumn Header="Rj" Binding="{Binding Rj}" Width="35"/>
                                    <DataGridTextColumn Header="Rk" Binding="{Binding Rk}" Width="35"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Stare Instrucțiuni" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding InstrTable}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Instrucțiune" Binding="{Binding Instr}" Width="*"/>
                                    <DataGridTextColumn Header="FU" Binding="{Binding Fu}" Width="60"/>
                                    <DataGridTextColumn Header="Issue" Binding="{Binding Issue}" Width="45"/>
                                    <DataGridTextColumn Header="Read Op" Binding="{Binding Read}" Width="55"/>
                                    <DataGridTextColumn Header="Exec Done" Binding="{Binding ExecDone}" Width="65"/>
                                    <DataGridTextColumn Header="Write" Binding="{Binding Write}" Width="45"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Reg → FU" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding RegResultTable}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Reg" Binding="{Binding Reg}" Width="40"/>
                                    <DataGridTextColumn Header="Valoare" Binding="{Binding Value}" Width="60"/>
                                    <DataGridTextColumn Header="FU" Binding="{Binding Fu}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ===== TAB 3: TOMASULO ===== -->
        <TabItem Header="1.2 — Tomasulo" DataContext="{Binding Tomasulo}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ProgramSource, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" FontFamily="Consolas" FontSize="11" Background="White" Foreground="#1E1E1E"
                                 BorderBrush="#D0D0D0" Height="80" VerticalScrollBarVisibility="Auto" Padding="4" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Start PC:" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                                <TextBox Grid.Column="1" Text="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Background="White" Foreground="#1A7A5A" FontFamily="Consolas" Height="22"
                                         BorderBrush="#D0D0D0" Margin="6,0,0,0" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding Status}" Foreground="#C0392B" FontSize="10" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CdbInfo}" Foreground="#F9A825" FontSize="11" FontFamily="Consolas" Margin="0,4,0,0"/>
                            <TextBlock FontSize="11" Margin="0,2,0,0">
                                <Run Text="Tact: " Foreground="#555"/>
                                <Run Text="{Binding CycleCount}" Foreground="#1A5276" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Button Content="LOAD" Command="{Binding LoadCommand}" Style="{StaticResource ClockButton}" Margin="0,0,0,4"/>
                            <Button Content="TICK" Command="{Binding TickCommand}" Style="{StaticResource ClockButton}" Background="#D4E6F1" Foreground="#1A5276" BorderBrush="#85A9C4" Margin="0,0,0,4"/>
                            <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ClockButton}" Background="#FDDEDE" Foreground="#C0392B" BorderBrush="#D32F2F"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Stații de Rezervare (ALU×4, MUL×2, LDST×2, JMP×2)" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding RSTable}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="70"/>
                                    <DataGridTextColumn Header="Busy" Binding="{Binding Busy}" Width="40"/>
                                    <DataGridTextColumn Header="Op" Binding="{Binding Op}" Width="60"/>
                                    <DataGridTextColumn Header="Vj" Binding="{Binding Vj}" Width="60"/>
                                    <DataGridTextColumn Header="Vk" Binding="{Binding Vk}" Width="60"/>
                                    <DataGridTextColumn Header="Qj" Binding="{Binding Qj}" Width="70"/>
                                    <DataGridTextColumn Header="Qk" Binding="{Binding Qk}" Width="70"/>
                                    <DataGridTextColumn Header="Stare" Binding="{Binding State}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Registre (Valoare + Tag Qi)" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding RegTable}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Reg" Binding="{Binding Reg}" Width="40"/>
                                    <DataGridTextColumn Header="Valoare" Binding="{Binding Value}" Width="*"/>
                                    <DataGridTextColumn Header="Qi" Binding="{Binding Qi}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ===== TAB 4: OoO ===== -->
        <TabItem Header="1.3 — Prefetch + OoO + ROB" DataContext="{Binding Ooo}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ProgramSource, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" FontFamily="Consolas" FontSize="11" Background="White" Foreground="#1E1E1E"
                                 BorderBrush="#D0D0D0" Height="80" VerticalScrollBarVisibility="Auto" Padding="4" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Start PC:" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                                <TextBox Grid.Column="1" Text="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Background="White" Foreground="#1A7A5A" FontFamily="Consolas" Height="22"
                                         BorderBrush="#D0D0D0" Margin="6,0,0,0" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding Status}" Foreground="#C0392B" FontSize="10" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding FuStatus}" Foreground="#1A7A5A" FontSize="10" FontFamily="Consolas" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                            <TextBlock FontSize="11" Margin="0,3,0,0">
                                <Run Text="Tact: " Foreground="#555"/>
                                <Run Text="{Binding CycleCount}" Foreground="#1A5276" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Button Content="LOAD" Command="{Binding LoadCommand}" Style="{StaticResource ClockButton}" Margin="0,0,0,4"/>
                            <Button Content="TICK" Command="{Binding TickCommand}" Style="{StaticResource ClockButton}" Background="#D4E6F1" Foreground="#1A5276" BorderBrush="#85A9C4" Margin="0,0,0,4"/>
                            <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ClockButton}" Background="#FDDEDE" Foreground="#C0392B" BorderBrush="#D32F2F"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Prefetch Buffers -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,6,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Buffer Secvențial" Foreground="#2C5F8A" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding PrimaryBufferRows}" Style="{StaticResource AlgoGrid}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Instrucțiune" Binding="{Binding InstrLabel}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,6,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Buffer Branch Target" Foreground="#F9A825" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding BranchBufferRows}" Style="{StaticResource AlgoGrid}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Instrucțiune" Binding="{Binding InstrLabel}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Instruction Window -->
                    <Border Grid.Column="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Fereastră Instrucțiuni (OoO Issue)" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding WindowRows}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="60"/>
                                    <DataGridTextColumn Header="Instrucțiune" Binding="{Binding Instr}" Width="*"/>
                                    <DataGridTextColumn Header="Vj" Binding="{Binding Vj}" Width="50"/>
                                    <DataGridTextColumn Header="Vk" Binding="{Binding Vk}" Width="50"/>
                                    <DataGridTextColumn Header="Qj" Binding="{Binding Qj}" Width="60"/>
                                    <DataGridTextColumn Header="Qk" Binding="{Binding Qk}" Width="60"/>
                                    <DataGridTextColumn Header="Stare" Binding="{Binding State}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Reorder Buffer -->
                    <Border Grid.Column="2" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Reorder Buffer (Commit în Ordine)" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding RobRows}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="60"/>
                                    <DataGridTextColumn Header="Instrucțiune" Binding="{Binding Instr}" Width="*"/>
                                    <DataGridTextColumn Header="Dest" Binding="{Binding Dest}" Width="45"/>
                                    <DataGridTextColumn Header="Valoare" Binding="{Binding Value}" Width="60"/>
                                    <DataGridTextColumn Header="Ready" Binding="{Binding Ready}" Width="45"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Registre -->
                    <Border Grid.Column="3" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Registre + Rename Tags" Foreground="#6A1B9A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding RegTable}" Style="{StaticResource AlgoGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Reg" Binding="{Binding Reg}" Width="40"/>
                                    <DataGridTextColumn Header="Val" Binding="{Binding Value}" Width="*"/>
                                    <DataGridTextColumn Header="Tag" Binding="{Binding Qi}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
