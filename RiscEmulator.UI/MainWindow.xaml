<Window x:Class="RiscEmulator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RiscEmulator.UI.ViewModels"
        Title="Simulator RISC Pipeline" Height="780" Width="1200"
        Background="#1E1E1E" Foreground="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PanelLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00FF88"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#88AAFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#52B788"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: editor + butoane -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Cod sursă assembler RISC" Style="{StaticResource SectionHeader}"/>
                <TextBox Text="{Binding ProgramSource, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" FontFamily="Consolas" FontSize="13"
                         Background="#252526" Foreground="#D4D4D4" BorderBrush="#555"
                         VerticalScrollBarVisibility="Auto" Height="130"
                         Padding="6"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Width="160">
                <Button Content="Load Program" Command="{Binding LoadProgramCommand}"
                        Style="{StaticResource ActionButton}" Margin="0,0,0,6"/>
                <Button Content="Next Clock ▶" Command="{Binding NextClockCommand}"
                        Style="{StaticResource ActionButton}" Margin="0,0,0,6"
                        Background="#1B4332" BorderBrush="#40916C"/>
                <Button Content="Reset" Command="{Binding ResetCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="#6D1A1A" BorderBrush="#C0392B"/>
                <TextBlock Margin="0,8,0,0">
                    <Run Text="Tact #" Foreground="#AAAAAA"/>
                    <Run Text="{Binding CycleCount}" Foreground="#FFD166"
                         FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Middle: pipeline + registre + memorie -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <!-- Pipeline stages -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Pipeline — 5 stagii (IF / DEC-OF / EX / MEM / WB)"
                           Style="{StaticResource SectionHeader}"/>
                <ItemsControl ItemsSource="{Binding PipelineSlots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" Padding="10,8" CornerRadius="4"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#252526"/>
                                        <Setter Property="BorderBrush" Value="#444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStall}" Value="True">
                                                <Setter Property="Background" Value="#3D1515"/>
                                                <Setter Property="BorderBrush" Value="#C0392B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasForwarding}" Value="True">
                                                <Setter Property="Background" Value="#2D2D10"/>
                                                <Setter Property="BorderBrush" Value="#F0C030"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StageName}"
                                               FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="#88AAFF" FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding InstructionLabel}"
                                               FontFamily="Consolas" FontSize="14"
                                               Foreground="#00FF88" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <TextBlock Foreground="#FF6B6B" FontSize="11"
                                                   FontWeight="Bold" VerticalAlignment="Center"
                                                   Margin="6,0,0,0" Text="STALL">
                                            <TextBlock.Visibility>
                                                <Binding Path="IsStall"
                                                         Converter="{StaticResource BoolToVis}"/>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                        <TextBlock Foreground="#FFD166" FontSize="11"
                                                   FontWeight="Bold" VerticalAlignment="Center"
                                                   Margin="6,0,0,0" Text="FWD">
                                            <TextBlock.Visibility>
                                                <Binding Path="HasForwarding"
                                                         Converter="{StaticResource BoolToVis}"/>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Registre interne procesor -->
                <TextBlock Text="Registre interne (§2)" Style="{StaticResource SectionHeader}"
                           Margin="0,12,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/>
                        <ColumnDefinition/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Text="PC" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Style="{StaticResource ValueLabel}">
                            <Run Text="0x"/>
                            <Run Text="{Binding PC, StringFormat=X4}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                        <TextBlock Text="MAR" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Style="{StaticResource ValueLabel}">
                            <Run Text="0x"/>
                            <Run Text="{Binding MAR, StringFormat=X4}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,8">
                        <TextBlock Text="MDR" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Style="{StaticResource ValueLabel}">
                            <Run Text="0x"/>
                            <Run Text="{Binding MDR, StringFormat=X4}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,8">
                        <TextBlock Text="IR" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Style="{StaticResource ValueLabel}">
                            <Run Text="0x"/>
                            <Run Text="{Binding IR, StringFormat=X4}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="A (tampon)" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Text="{Binding RegA}" Style="{StaticResource ValueLabel}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="B (tampon)" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Text="{Binding RegB}" Style="{StaticResource ValueLabel}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="C (tampon)" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Text="{Binding RegC}" Style="{StaticResource ValueLabel}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="3">
                        <TextBlock Text="ISA" Style="{StaticResource PanelLabel}"/>
                        <TextBlock Text="RISC Load/Store" Style="{StaticResource ValueLabel}" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Fișier de registre -->
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Fișier registre R0–R31" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Verde=valid  Roșu=invalid(I)"
                           Style="{StaticResource PanelLabel}" Margin="0,0,0,6"/>
                <ItemsControl ItemsSource="{Binding Registers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="#88AAFF"/>
                                <TextBlock Grid.Column="1" Text="{Binding DisplayValue}"
                                           FontFamily="Consolas" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#00FF88"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding StatusLabel}"
                                           FontFamily="Consolas" FontSize="11"
                                           HorizontalAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#00FF88"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Memorie -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Memorie (adrese non-zero)"
                           Style="{StaticResource SectionHeader}"/>
                <ListView ItemsSource="{Binding MemoryRows}"
                          Background="#252526" BorderBrush="#444"
                          Foreground="#D4D4D4" FontFamily="Consolas" FontSize="12"
                          MaxHeight="400">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Adresă" Width="70"
                                            DisplayMemberBinding="{Binding AddressHex}"/>
                            <GridViewColumn Header="Valoare" Width="70"
                                            DisplayMemberBinding="{Binding ValueHex}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#252526" Padding="8,4" Margin="0,8,0,0"
                BorderBrush="#444" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#FFD166"
                       FontFamily="Consolas" FontSize="12"/>
        </Border>
    </Grid>

</Window>
